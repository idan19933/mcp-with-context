# Clarity PPM Connection
CLARITY_BASE_URL=https://your-clarity-server.com/ppm/rest/v1
CLARITY_USERNAME=your_username
CLARITY_PASSWORD=your_password
# Or use session-based auth:
# CLARITY_SESSION_ID=your_session_id
# Or use token auth:
# CLARITY_AUTH_TOKEN=your_token

# Anthropic API (for AI Chat)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server
PORT=3000
